# =============================================================================
# GLPI 10.0.24 — Deployment Environment Configuration
# =============================================================================
# This file contains settings for the GLPI deployment script.
# Copy this to glpi.env, edit the values for your environment, then run:
#   sudo bash glpi.sh --env ./glpi.env
#
# SECURITY WARNING:
#   chmod 600 glpi.env
#   echo 'glpi.env' >> .gitignore
#   Never commit secrets to version control.
#   Rotate DB passwords after first successful deployment.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# GLPI Application Settings
# ─────────────────────────────────────────────────────────────────────────────

# GLPI version — ensure it matches the release tag on GitHub
# https://github.com/glpi-project/glpi/releases
GLPI_VERSION="10.0.24"

# GLPI hostname — used for TLS certificate, nginx config, and /etc/hosts
# Must be resolvable on the network (DNS or /etc/hosts)
GLPI_HOSTNAME="glpi.example.com"

# Static IP of the GLPI host (used in /etc/hosts and firewall rules)
GLPI_IP="192.168.100.50"

# Timezone — used by GLPI and PHP (see https://www.php.net/manual/en/timezones.php)
# Common values: UTC, Europe/London, US/Eastern, Asia/Manila, Australia/Sydney
GLPI_TZ="UTC"

# ─────────────────────────────────────────────────────────────────────────────
# Directory Layout
# ─────────────────────────────────────────────────────────────────────────────

# Base directory for GLPI volumes, config, and logs — must exist and be writable
# GLPI_WEBROOT is derived at runtime: ${GLPI_BASE}/webroot
# Don't use /tmp (temporary files get deleted) or /home (user perms issues)
GLPI_BASE="/opt/glpi"

# ─────────────────────────────────────────────────────────────────────────────
# Network Ports
# ─────────────────────────────────────────────────────────────────────────────

# External HTTPS port — expose to network for end-user access (default 443)
NGINX_HTTPS_PORT="9443"

# External HTTP port — redirects to HTTPS (default 80)
NGINX_HTTP_PORT="9080"

# Host loopback port — internal only, mapped to compose nginx
# Compose nginx runs on localhost:POD_HOST_PORT; host nginx reverses proxy to it
# Keep on loopback (127.0.0.1) — do not expose this to the network
POD_HOST_PORT="8081"

# Compose-internal nginx listen port — used only inside the container network
# Not exposed to host unless mapped via POD_HOST_PORT
COMPOSE_PORT="8082"

# ─────────────────────────────────────────────────────────────────────────────
# Container Images
# ─────────────────────────────────────────────────────────────────────────────

# PHP-FPM base image — must be Alpine Linux to keep size small
# Updates: check https://hub.docker.com/_/php for latest tags
IMG_PHP="docker.io/library/php:8.3-fpm-alpine"

# nginx reverse proxy image — Alpine Linux
IMG_NGINX="docker.io/library/nginx:1.26-alpine"

# MariaDB (MySQL) image — 10.11 is LTS
IMG_MARIADB="docker.io/library/mariadb:10.11"

# GLPI app image — built locally, derived from IMG_PHP + GLPI source
# Tag format: localhost/glpi-app:${GLPI_VERSION}
# Don't change this unless you want a custom image name

# ─────────────────────────────────────────────────────────────────────────────
# Service User (Rootless Podman)
# ─────────────────────────────────────────────────────────────────────────────

# Service account name — created if it doesn't exist
# Used to run rootless podman containers and own all GLPI files
GLPI_USER="glpi"
GLPI_GROUP="glpi"

# Fixed UID/GID — ensures consistency across redeploys and backups
# Use values > 1000 to avoid conflict with system accounts
# Set to empty "" to let the system auto-assign
GLPI_UID="1500"
GLPI_GID="1500"

# www-data UID/GID inside the Alpine PHP-FPM container
# Don't change these — they're fixed in Alpine Linux
WWW_UID="82"
WWW_GID="82"

# ─────────────────────────────────────────────────────────────────────────────
# Database Credentials
# ─────────────────────────────────────────────────────────────────────────────

# MariaDB root password — set once at deploy time, then ignored
# Leave blank ("") to auto-generate 32-byte random password via openssl rand
# If set, must be 12+ characters, avoid single quotes and shell metacharacters
DB_ROOT_PASSWORD_HINT=""

# MariaDB glpiuser password — for application database access
# Leave blank to auto-generate; set to override
DB_PASSWORD_HINT=""

# Database name — GLPI schema
MARIADB_DATABASE="glpidb"

# Database user — owns glpidb schema and connects from glpi-app container
MARIADB_USER="glpiuser"

# ─────────────────────────────────────────────────────────────────────────────
# Cross-Host Service Hostnames
# ─────────────────────────────────────────────────────────────────────────────
# Specify the hostnames of external services (SMTP, LDAP, Zabbix).
# The script will resolve these via DNS or /etc/hosts.
# Leave blank if not used.

# Mail relay (SMTP) — for sending alerts and notifications
MAIL_HOST="mail.example.com"

# Zabbix monitoring — for metrics ingestion and integration
ZABBIX_HOST="zabbix.example.com"

# Identity management (LDAP/FreeIPA) — for user authentication and groups
IDM_HOST="idm.example.com"

# ─────────────────────────────────────────────────────────────────────────────
# SMTP Configuration (Mail Relay)
# ─────────────────────────────────────────────────────────────────────────────
# Settings displayed in post-install checklist and used to configure
# GLPI email notifications. Configure these in GLPI UI after deploy.

# SMTP relay hostname or IP — same as MAIL_HOST above
SMTP_HOST="mail.example.com"

# SMTP port — 25 (unencrypted), 587 (STARTTLS), 465 (implicit TLS)
SMTP_PORT="587"

# From address — used in GLPI email headers
# Can be any address; typically matches a mailbox on the relay
SMTP_FROM="glpi@example.com"

# Optional: SMTP username and password (if relay requires auth)
# Uncomment and fill if needed; otherwise leave commented
# SMTP_USER="glpi"
# SMTP_PASSWORD="secretpassword"

# ─────────────────────────────────────────────────────────────────────────────
# Zabbix Agent (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Set to 1 to install zabbix-agent2 on the host OS for monitoring

# Enable Zabbix agent installation (0 = skip, 1 = install)
ZABBIX_AGENT_ENABLE="0"

# Zabbix server address — if ZABBIX_AGENT_ENABLE=1, agent reports to this address
ZABBIX_SERVER="zabbix.example.com"

# ─────────────────────────────────────────────────────────────────────────────
# Backup Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Backup directory on the host — must exist and have 5+ GB free
# Backups include MariaDB dumps and GLPI files volumes
BACKUP_DIR="/opt/glpi-backups"

# How many days to keep backups before automatic deletion
# Set to 14 to keep 2 weeks of daily backups
BACKUP_RETENTION_DAYS="14"

# Backup schedule (OnCalendar format) — systemd timer syntax
# Examples:
#   *-*-* 02:00:00        = daily at 2:00 AM
#   Mon,Wed,Fri *-*-* 03:00:00  = Mon/Wed/Fri at 3:00 AM
#   *-*-1 04:00:00        = monthly on day 1 at 4:00 AM
BACKUP_SCHEDULE="*-*-* 02:00:00"

# ─────────────────────────────────────────────────────────────────────────────
# SELinux Policy
# ─────────────────────────────────────────────────────────────────────────────

# Custom SELinux policy name — created if SELinux is active
# Allows containers to access files and ports
SELINUX_POLICY_NAME="glpi_podman"

# ─────────────────────────────────────────────────────────────────────────────
# Compose Project Name
# ─────────────────────────────────────────────────────────────────────────────

# Podman compose project identifier — used for container naming and logging
# Change if you're running multiple GLPI stacks on the same host
COMPOSE_PROJECT="glpi"

# =============================================================================
# NEXT STEPS
# =============================================================================
# 1. Edit this file and fill in your values
# 2. Save as glpi.env in the same directory as glpi.sh
# 3. Run dry-run:   sudo bash glpi.sh --env ./glpi.env --dry-run
# 4. Deploy:        sudo bash glpi.sh --env ./glpi.env
# 5. Follow SETUP.md for post-install configuration
